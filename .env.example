# EIC Data — eic-data-web 環境変数 scaffold
#
# Phase C Day 5 午後タスク 3 (2026-05-16) で初版作成。
# Tier 2 Newsletter (Resend Free 連携) の env scaffold。
#
# 本番設定は Vercel Project Settings > Environment Variables で管理。
# ローカル開発は .env.local にコピーして使用 (gitignore 対象)。

# === Resend (Tier 2 Newsletter, /api/newsletter) ===
# https://resend.com/api-keys で取得 (Free tier: 100 emails/day, 3,000/月)
# 未設定でも /api/newsletter は購読データを返却 (scaffold: true で確認メール非送信)。
RESEND_API_KEY=

# 送信元メールアドレス (Resend に検証済ドメインで設定)
# デフォルト: "EIC Data <onboarding@resend.dev>" (Resend 共有 sandbox、Domain 未設定でも送信可)
RESEND_FROM=

# 既存 Audience の ID を直指定 (省略時は /audiences list/create で自動解決)
# Day 5 午後第 5 弾 (2026-05-16) で Double opt-in 実装。
RESEND_AUDIENCE_ID=

# === Newsletter Token (confirm/unsubscribe) ===
# Double opt-in / 1-click 解除リンクの HMAC-SHA256 秘密鍵 (16 文字以上推奨)
# 未設定時は demo 鍵で動作 (本番では必ず設定)。
NEWSLETTER_SECRET=

# Confirm/unsubscribe link の base URL (省略時 "https://data.eic-jp.org")
NEWSLETTER_BASE_URL=

# === N6 API 認証 (Day 5 午後第 4 弾) ===
# /api/auth で発行する Bearer Token の HMAC-SHA256 秘密鍵 (16 文字以上推奨)
# 未設定時は demo:true で動作 (本番では必ず設定)。
API_AUTH_SECRET=

# === N3 編集者通知 (Day 5 午後第 3 弾) ===
# Insight 公開時に通知するメールアドレス (カンマ区切り)
EDITOR_NOTIFY_TO=
